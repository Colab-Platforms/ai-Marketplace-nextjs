generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum UserRole {
  USER
  VENDOR
  ADMIN
  SUPERADMIN
}

model users {
  id        String @id @default(cuid())

  firstName    String
  lastName     String
  name         String
  email        String  @unique
  phone_number String? @unique
  avatar_url   String?

  role UserRole @default(USER)

  password     String?
  authProvider AuthProvider @default(LOCAL)
  googleId     String?      @unique

  emailVerificationOtpHash      String?
  emailVerificationOtpExpiresAt DateTime?

  passwordResetOtpHash      String?
  passwordResetOtpExpiresAt DateTime?

  isGuideTaken  Boolean  @default(false)
  isActive      Boolean  @default(true)
  isVerified    Boolean  @default(false)
  isDeleted     Boolean  @default(false)
  timezone      String   @default("Asia/Kolkata")
  last_login_at DateTime?
  deletedAt     DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  sessions user_sessions[]
  passwordResetTokens passwordResetToken[]
  vendor   vendors?
  subscriptions subscriptions[]
  payments      payments[]
  tool_access   tool_access[]
  reviews       reviews[]
  notifications notifications[]
}

model vendors {
  id            String @id @default(cuid())
  owner_user_id String @unique

  company_name          String
  brand_name            String?
  company_type          String?
  gstNumber             String?   @unique // GST
  registaration_number  String?   @unique //CIN
  pan_number            String?   @unique //PAN
  registered_address    String?
  date_of_incorporation DateTime?
  website_url           String?
  description           String?
  country               String?
  state                 String?
  city                  String?

  verification_status String
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  owner users @relation(fields: [owner_user_id], references: [id])

  tools   tools[]
  payouts payouts[]

  vendor_docs vendor_docs[]
}

model vendor_docs {
  id                  String   @id @default(cuid())
  vendor_id           String
  doc_type            String
  doc_url             String
  verification_status String
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  vendor              vendors  @relation(fields: [vendor_id], references: [id])
}

model user_sessions {
  id String @id @default(cuid())

  user_id String

  refresh_token String
  expires_at    DateTime
  created_at    DateTime @default(now())

  user users @relation(fields: [user_id], references: [id])
}

model passwordResetToken {
  id        String @id @default(cuid())
  user_id   String
  token     String @unique
  expires_at DateTime
  used      Boolean  @default(false)
  created_at DateTime @default(now())

  user users @relation(fields: [user_id], references: [id])

  @@index([user_id, used])
}

model categories {
  id   String @id @default(cuid())
  name String
  slug String @unique

  created_at DateTime @default(now())

  tools tools[]
}

model tags {
  id   String @id @default(cuid())
  name String
  slug String @unique

  tool_tags tool_tags[]
}

model tools {
  id          String @id @default(cuid())
  vendor_id   String
  category_id String

  name              String
  slug              String @unique
  short_description String?
  full_description  String?

  logo_url    String?
  website_url String?
  demo_url    String?

  pricing_model String
  status        String

  average_rating Float?
  total_reviews  Int @default(0)
  total_views    Int @default(0)
  total_launches Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  isDeleted     Boolean  @default(false)
  vendor   vendors    @relation(fields: [vendor_id], references: [id])
  category categories @relation(fields: [category_id], references: [id])

  images          tool_images[]
  tool_tags       tool_tags[]
  pricing_plans   pricing_plans[]
  subscriptions   subscriptions[]
  vendor_webhooks vendor_webhooks[]
  webhook_logs    webhook_logs[]
  tool_access     tool_access[]
  reviews         reviews[]
}

model tool_images {
  id      String @id @default(cuid())
  tool_id String

  image_url String

  created_at DateTime @default(now())

  tool tools @relation(fields: [tool_id], references: [id])
}

model tool_tags {
  id      String @id @default(cuid())
  tool_id String
  tag_id  String

  tool tools @relation(fields: [tool_id], references: [id])
  tag  tags  @relation(fields: [tag_id], references: [id])

  @@unique([tool_id, tag_id])
}

model pricing_plans {
  id      String @id @default(cuid())
  tool_id String

  name        String
  description String?

  billing_cycle String
  price         Float
  currency      String

  trial_days Int?

  is_active Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tool tools @relation(fields: [tool_id], references: [id])

  plan_features plan_features[]
  subscriptions subscriptions[]
}

model plan_features {
  id      String @id @default(cuid())
  plan_id String

  feature_name String

  plan pricing_plans @relation(fields: [plan_id], references: [id])
}

model subscriptions {
  id      String @id @default(cuid())
  user_id String
  tool_id String
  plan_id String

  status String

  start_date DateTime
  end_date   DateTime?

  auto_renew Boolean @default(false)

  created_at DateTime @default(now())

  user users @relation(fields: [user_id], references: [id])
  tool tools @relation(fields: [tool_id], references: [id])
  plan pricing_plans @relation(fields: [plan_id], references: [id])

  payments    payments[]
  tool_access tool_access[]
  events      subscription_events[]

  @@index([user_id, tool_id])
}

model payments {
  id              String @id @default(cuid())
  user_id         String
  subscription_id String

  amount Float

  currency String

  payment_gateway       String
  gateway_transaction_id String @unique

  status String

  paid_at DateTime?

  user         users         @relation(fields: [user_id], references: [id])
  subscription subscriptions @relation(fields: [subscription_id], references: [id])

  invoice invoices?
}

model invoices {
  id String @id @default(cuid())

  payment_id String @unique

  invoice_number String @unique
  invoice_url    String

  created_at DateTime @default(now())

  payment payments @relation(fields: [payment_id], references: [id])
}

model payouts {
  id        String @id @default(cuid())
  vendor_id String

  amount Float

  status String

  payout_reference String?

  created_at DateTime @default(now())

  vendor vendors @relation(fields: [vendor_id], references: [id])
}

model vendor_webhooks {
  id      String @id @default(cuid())
  tool_id String

  webhook_url    String
  webhook_secret String

  is_active Boolean @default(true)

  created_at DateTime @default(now())

  tool tools @relation(fields: [tool_id], references: [id])
}

model webhook_logs {
  id      String @id @default(cuid())
  tool_id String

  event_type String

  request_payload  String
  response_payload String?

  response_code Int?

  status String

  created_at DateTime @default(now())

  tool tools @relation(fields: [tool_id], references: [id])
}

model tool_access {
  id              String @id @default(cuid())
  user_id         String
  tool_id         String
  subscription_id String

  external_user_id String?
  launch_url       String?

  status String

  created_at DateTime @default(now())

  user         users         @relation(fields: [user_id], references: [id])
  tool         tools         @relation(fields: [tool_id], references: [id])
  subscription subscriptions @relation(fields: [subscription_id], references: [id])
}

model subscription_events {
  id              String @id @default(cuid())
  subscription_id String

  event_type String
  payload    String?

  created_at DateTime @default(now())

  subscription subscriptions @relation(fields: [subscription_id], references: [id])
}

model reviews {
  id      String @id @default(cuid())
  user_id String
  tool_id String

  rating Int

  title  String?
  review String?

  created_at DateTime @default(now())

  user users @relation(fields: [user_id], references: [id])
  tool tools @relation(fields: [tool_id], references: [id])

  @@unique([user_id, tool_id])
}

model notifications {
  id      String @id @default(cuid())
  user_id String

  title String
  body  String

  type String

  is_read Boolean @default(false)

  created_at DateTime @default(now())

  user users @relation(fields: [user_id], references: [id])
}

model uploaded_files {
  id         String   @id @default(cuid())
  public_id  String   @unique
  url        String   @unique
  status     String   // PENDING, USED
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}
